filters:
  and:
    - file.path.startsWith("Dev/Services/")
    - file.hasTag("explainability")
views:
  - type: table
    name: Explicabilité des modèles
    order:
      - file.name
      - pitch
      - langage
      - licence_type
      - maturite
      - scaling
      - tags
      - alternatives
    sort:
      - property: file.name
        direction: asc
