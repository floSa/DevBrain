filters:
  and:
    - file.path.startsWith("Dev/Services/")
    - categorie == "data/scraping"
views:
  - type: table
    name: Scraping
    order:
      - file.name
      - pitch
      - langage
      - licence_type
      - maturite
      - scaling
      - tags
      - alternatives
    sort:
      - property: file.name
        direction: asc
  - type: table
    name: Parsing HTML
    filters:
      and:
        - file.hasTag("document-parsing")
    order:
      - file.name
      - pitch
      - langage
      - scaling
      - alternatives
    sort:
      - property: file.name
        direction: asc
