filters:
  and:
    - file.path.startsWith("Dev/Services/")
    - categorie == "data/parsing"
views:
  - type: table
    name: Parsing de documents
    order:
      - file.name
      - pitch
      - langage
      - licence_type
      - maturite
      - hosted
      - scaling
      - tags
      - alternatives
    sort:
      - property: file.name
        direction: asc
  - type: table
    name: Orientés RAG / conversion
    filters:
      and:
        - tags.contains("rag")
    order:
      - file.name
      - pitch
      - licence_type
      - hosted
      - alternatives
    sort:
      - property: file.name
        direction: asc
